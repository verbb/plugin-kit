{
    "name": "@verbb/plugin-kit-tiptap-core",
    "version": "2.0.3",
    "type": "module",
    "main": "dist/index.js",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist",
        "CHANGELOG.md",
        "LICENSE.md"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/verbb/plugin-kit.git",
        "directory": "plugin-kit-tiptap-core"
    },
    "bugs": {
        "url": "https://github.com/verbb/plugin-kit/issues"
    },
    "homepage": "https://docs.verbb.io/plugin-kit",
    "engines": {
        "node": ">=20.0.0"
    },
    "publishConfig": {
        "access": "public"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./serialization/editor": {
            "types": "./dist/serialization/editor.d.ts",
            "import": "./dist/serialization/editor.js"
        },
        "./serialization/input": {
            "types": "./dist/serialization/input.d.ts",
            "import": "./dist/serialization/input.js"
        },
        "./links": {
            "types": "./dist/links/index.d.ts",
            "import": "./dist/links/index.js"
        },
        "./extensions": {
            "types": "./dist/extensions/index.d.ts",
            "import": "./dist/extensions/index.js"
        },
        "./toolbar": {
            "types": "./dist/toolbar/index.d.ts",
            "import": "./dist/toolbar/index.js"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "build": "vite build",
        "dev": "vite build --watch",
        "test": "vitest run"
    },
    "license": "MIT",
