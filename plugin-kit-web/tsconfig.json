{
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "skipLibCheck": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "outDir": "dist",
        "rootDir": "src",
        "noEmit": true,
        "isolatedModules": true,
        "verbatimModuleSyntax": true,
        "experimentalDecorators": true,
        "useDefineForClassFields": false
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules", "dist", "dev", "src/components/_legacy"]
}
