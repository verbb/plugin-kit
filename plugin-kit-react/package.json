{
    "name": "@verbb/plugin-kit-react",
    "version": "2.0.0",
    "description": "Thin React facades over @verbb/plugin-kit-web custom elements",
    "type": "module",
    "main": "dist/index.js",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "sideEffects": [
        "*.css"
    ],
    "files": [
        "dist",
        "style.css",
        "tailwind-theme.css",
        "tailwind-preflight-scope.css",
        "vite-dev.mjs",
        "LICENSE.md",
        "CHANGELOG.md"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/verbb/plugin-kit.git",
        "directory": "plugin-kit-react"
    },
    "bugs": {
        "url": "https://github.com/verbb/plugin-kit/issues"
    },
    "homepage": "https://docs.verbb.io/plugin-kit",
    "engines": {
        "node": ">=20.0.0"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./components": {
            "types": "./dist/components/index.d.ts",
            "import": "./dist/components/index.js"
        },
        "./components/*": {
            "types": "./dist/components/*.d.ts",
            "import": "./dist/components/*.js"
        },
        "./app": {
            "types": "./dist/app/index.d.ts",
            "import": "./dist/app/index.js"
        },
        "./forms": {
            "types": "./dist/forms/index.d.ts",
            "import": "./dist/forms/index.js"
        },
        "./forms/*": {
            "types": "./dist/forms/*.d.ts",
            "import": "./dist/forms/*.js"
        },
        "./hooks": {
            "types": "./dist/hooks/index.d.ts",
            "import": "./dist/hooks/index.js"
        },
        "./hooks/*": {
            "types": "./dist/hooks/*.d.ts",
            "import": "./dist/hooks/*.js"
        },
        "./fault": {
            "types": "./dist/fault/index.d.ts",
            "import": "./dist/fault/index.js"
        },
        "./utils": {
            "types": "./dist/utils/index.d.ts",
            "import": "./dist/utils/index.js"
        },
        "./utils/*": {
            "types": "./dist/utils/*.d.ts",
            "import": "./dist/utils/*.js"
        },
        "./style.css": {
            "style": "./style.css",
            "default": "./style.css"
        },
        "./tailwind-theme.css": {
            "style": "./tailwind-theme.css",
            "default": "./tailwind-theme.css"
        },
        "./tailwind-preflight-scope.css": {
            "style": "./tailwind-preflight-scope.css",
            "default": "./tailwind-preflight-scope.css"
        },
        "./package.json": "./package.json",
        "./vite-dev": "./vite-dev.mjs"
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "vite build",
        "dev": "vite build --watch",
        "test": "vitest run"
    },
    "license": "MIT",
    "devDependencies": {
        "@types/node": "^25.6.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "typescript": "^6.0.3",
        "vite": "^8.0.10",
        "vite-plugin-dts": "^4.5.4",
        "vitest": "^4.1.5"
    },
    "peerDependencies": {
        "react": "^19.2.5",
        "react-dom": "^19.2.5"
    },
    "dependencies": {
        "@lit/react": "^1.0.8",
        "@verbb/plugin-kit-core": "2.0.0",
        "@verbb/plugin-kit-forms": "2.0.0",
        "@verbb/plugin-kit-web": "2.0.0",
        "clsx": "^2.1.1",
        "tailwind-merge": "^3.5.0"
    }
}
