{
    "name": "@verbb/plugin-kit-vue",
    "version": "2.0.4",
    "description": "Vue adapters for @verbb/plugin-kit-web custom elements",
    "type": "module",
    "types": "dist/index.d.ts",
    "sideEffects": [
        "*.css"
    ],
    "files": [
        "dist",
        "style.css",
        "tailwind-theme.css",
        "tailwind-preflight-scope.css",
        "vite-dev.mjs",
        "LICENSE.md",
        "CHANGELOG.md"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./components": {
            "types": "./dist/components/index.d.ts",
            "import": "./dist/components/index.js"
        },
        "./components/*": {
            "types": "./dist/components/*.d.ts",
            "import": "./dist/components/*.js"
        },
        "./app": {
            "types": "./dist/app/index.d.ts",
            "import": "./dist/app/index.js"
        },
        "./forms": {
            "types": "./dist/forms/index.d.ts",
            "import": "./dist/forms/index.js"
        },
        "./forms/*": {
            "types": "./dist/forms/*.d.ts",
            "import": "./dist/forms/*.js"
        },
        "./hooks": {
            "types": "./dist/hooks/index.d.ts",
            "import": "./dist/hooks/index.js"
        },
        "./hooks/*": {
            "types": "./dist/hooks/*.d.ts",
            "import": "./dist/hooks/*.js"
        },
        "./fault": {
            "types": "./dist/fault/index.d.ts",
            "import": "./dist/fault/index.js"
        },
        "./utils": {
            "types": "./dist/utils/index.d.ts",
            "import": "./dist/utils/index.js"
        },
        "./utils/*": {
            "types": "./dist/utils/*.d.ts",
            "import": "./dist/utils/*.js"
        },
        "./style.css": {
            "style": "./style.css",
            "default": "./style.css"
        },
        "./tailwind-theme.css": {
            "style": "./tailwind-theme.css",
            "default": "./tailwind-theme.css"
        },
        "./tailwind-preflight-scope.css": {
            "style": "./tailwind-preflight-scope.css",
            "default": "./tailwind-preflight-scope.css"
        },
        "./package.json": "./package.json",
        "./vite-dev": "./vite-dev.mjs"
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "vite build",
        "dev": "vite build --watch"
    },
    "license": "MIT",
    "dependencies": {
        "@lit-labs/vue-utils": "^0.1.3",
        "@verbb/plugin-kit-core": "2.0.4",
        "@verbb/plugin-kit-forms": "2.0.4",
        "@verbb/plugin-kit-web": "2.0.4",
        "clsx": "^2.1.1",
        "tailwind-merge": "^3.5.0"
    },
    "peerDependencies": {
        "vue": "^3.5.0"
    },
    "devDependencies": {
        "@vitejs/plugin-vue": "^6.0.1",
        "@vue/tsconfig": "^0.8.1",
        "typescript": "^6.0.3",
        "vite": "^8.0.10",
        "vite-plugin-dts": "^4.5.4",
        "vue": "^3.5.22"
    },
    "engines": {
        "node": ">=20.0.0"
    }
}
